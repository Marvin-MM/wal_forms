# =============================================================================
# WalrusForms Server — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_PORT=3000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3001

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://walrus_forms:walrus_forms@localhost:5432/walrus_forms?sslmode=disable

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_ISSUER=walrus-forms
JWT_AUDIENCE=walrus-forms-client

# -----------------------------------------------------------------------------
# Sui Blockchain
# -----------------------------------------------------------------------------
SUI_RPC_ENDPOINT=https://fullnode.testnet.sui.io:443
SUI_SERVER_WALLET_PRIVATE_KEY=suiprivkey1_CHANGE_ME
SUI_MOVE_PACKAGE_ID=0x_CHANGE_ME
SUI_MOVE_MODULE_NAME=walrus_forms

# -----------------------------------------------------------------------------
# Walrus Decentralized Storage
# -----------------------------------------------------------------------------
WALRUS_PUBLISHER_ENDPOINT=https://publisher.testnet.walrus.space
WALRUS_AGGREGATOR_ENDPOINT=https://aggregator.testnet.walrus.space
WALRUS_DEFAULT_EPOCHS=5

# -----------------------------------------------------------------------------
# Seal Encryption
# -----------------------------------------------------------------------------
SEAL_KEY_SERVER_ENDPOINT=https://seal-key-server.testnet.walrus.space
SEAL_PACKAGE_ID=0x_CHANGE_ME

# -----------------------------------------------------------------------------
# Anthropic Claude (AI)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# -----------------------------------------------------------------------------
# Inngest (Background Jobs)
# -----------------------------------------------------------------------------
# Local development:
#   INNGEST_DEV=true
#   bunx inngest-cli@latest dev -u http://localhost:5000/api/inngest
#
# Inngest Cloud:
#   INNGEST_DEV=false
#   Set real keys from https://app.inngest.com
#   Set INNGEST_SERVE_ORIGIN to your deployed HTTPS origin or tunnel URL.
INNGEST_DEV=true
INNGEST_ENV=
INNGEST_SIGNING_KEY=
INNGEST_SIGNING_KEY_FALLBACK=
INNGEST_EVENT_KEY=
INNGEST_SERVE_ORIGIN=
INNGEST_SERVE_PATH=/api/inngest

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (Abuse Prevention)
# -----------------------------------------------------------------------------
CLOUDFLARE_TURNSTILE_SECRET_KEY=0x_CHANGE_ME

# -----------------------------------------------------------------------------
# Rate Limiting (requests per minute)
# -----------------------------------------------------------------------------
RATE_LIMIT_SUBMISSION=10
RATE_LIMIT_UPLOAD=5
RATE_LIMIT_AI=3
RATE_LIMIT_AUTH=20
